{
  "uid": "spring-boot-jvm",
  "title": "Spring Boot JVM Metrics",
  "tags": ["spring", "jvm", "trading-simulator"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_memory_used_bytes, application)",
        "refresh": 2,
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$service\"}[1m])) by (uri, status)",
          "legendFormat": "{{uri}} [{{status}}]"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"$service\"}[1m])) by (le, uri))",
          "legendFormat": "p95 {{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"$service\", area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"$service\"}",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active DB Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"$service\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"$service\"}",
          "legendFormat": "Idle"
        }
      ]
    },
    {
      "id": 6,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"$service\"}",
          "legendFormat": "Live"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"$service\"}",
          "legendFormat": "Daemon"
        }
      ]
    },
    {
      "id": 7,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$service\", status=~\"5..\"}[1m])) by (uri)",
          "legendFormat": "5xx {{uri}}"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$service\", status=~\"4..\"}[1m])) by (uri)",
          "legendFormat": "4xx {{uri}}"
        }
      ]
    }
  ]
}
